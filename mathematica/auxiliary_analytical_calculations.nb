Cell[BoxData[{
 RowBox[{"Clear", "[", "\[CapitalSigma]ref", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[CapitalSigma]ref", "[", 
    RowBox[{
     RowBox[{"\[Xi]0_", "?", "NumericQ"}], ",", " ", 
     RowBox[{"\[ScriptCapitalA]0_", "?", "NumericQ"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"X", "=", 
        RowBox[{
         RowBox[{"-", "2"}], "\[Xi]0"}]}], ",", " ", 
       RowBox[{"a1", "=", 
        RowBox[{"2", "\[ScriptCapitalA]0"}]}]}], "}"}], ",", 
     RowBox[{"Simplify", "[", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"-", 
           FractionBox[
            RowBox[{"2", " ", "a1", " ", "\[Beta]"}], 
            RowBox[{"a1", "-", 
             RowBox[{"2", " ", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"-", "1"}], "+", 
                SqrtBox[
                 RowBox[{"1", "+", "a1"}]]}], ")"}], " ", "\[Beta]"}]}]]}], 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             SqrtBox[
              FractionBox["a1", "\[Pi]"]], 
             RowBox[{"(", 
              RowBox[{
               FractionBox[
                RowBox[{"1", "-", 
                 RowBox[{"Exp", "[", 
                  RowBox[{"-", "X"}], "]"}]}], 
                RowBox[{"2", 
                 SuperscriptBox["X", 
                  RowBox[{"3", "/", "2"}]]}]], "+", 
               FractionBox[
                RowBox[{"\[Eta]b", "-", 
                 RowBox[{"Exp", "[", 
                  RowBox[{"-", "X"}], "]"}]}], 
                SqrtBox["X"]]}], ")"}]}], "-", 
            RowBox[{"\[Eta]b", " ", 
             RowBox[{"ExpErfc", "[", 
              FractionBox["X", "a1"], "]"}]}], " ", "+", 
            RowBox[{
             SqrtBox[
              RowBox[{"1", "+", 
               FractionBox["1", "a1"]}]], 
             RowBox[{"(", 
              RowBox[{
               FractionBox[
                RowBox[{
                 RowBox[{"Exp", "[", 
                  RowBox[{"-", "X"}], "]"}], "-", "1"}], 
                SqrtBox[
                 RowBox[{"\[Pi]", " ", "X"}]]], "-", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{
                  RowBox[{"Exp", "[", 
                   FractionBox["X", "a1"], "]"}], 
                  FractionBox[
                   RowBox[{"Erfc", "[", 
                    SqrtBox[
                    RowBox[{"X", 
                    RowBox[{"(", 
                    RowBox[{"1", "+", 
                    FractionBox["1", "a1"]}], ")"}]}]], "]"}], 
                   RowBox[{"a1", 
                    SqrtBox[
                    RowBox[{"1", "+", 
                    FractionBox["1", "a1"]}]]}]]}], "-", 
                 FractionBox[
                  RowBox[{"ExpErfc", "[", 
                   FractionBox["X", "a1"], "]"}], 
                  SqrtBox["a1"]]}], " ", ")"}]}], ")"}]}]}], ")"}]}], "/.", 
         RowBox[{"{", 
          RowBox[{"\[Eta]b", "\[Rule]", " ", 
           FractionBox[
            RowBox[{"1", "-", "\[Nu]"}], 
            RowBox[{"2", 
             RowBox[{"(", 
              RowBox[{"\[Nu]u", "-", "\[Nu]"}], ")"}]}]]}], "}"}]}], "/.", 
        RowBox[{"{", 
         RowBox[{"\[Nu]u", "\[Rule]", 
          RowBox[{
           RowBox[{"\[Beta]", 
            RowBox[{"(", 
             RowBox[{"1", "-", "\[Nu]"}], ")"}]}], "+", "\[Nu]"}]}], "}"}]}], 
       ")"}], "]"}]}], "]"}]}], ";"}]}], "Input",

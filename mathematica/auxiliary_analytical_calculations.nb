Cell["\<\
\[CapitalPi](\[Xi],\[Zeta]) denotes the pore pressure field obtained from the \
boundary integral equation derived in the paper, whereas \
\[CapitalPi]ref(\[Xi],\[Zeta]) denotes the analytical reference solution \
derived by Atkinson-Craster.\
\>", "Text",
 CellChangeTimes->{{3.9900669022456856`*^9, 3.9900669873447895`*^9}, {
   3.9900670228426514`*^9, 3.990067041652794*^9}, 
   3.9900670837609234`*^9},ExpressionUUID->"4b4d92dd-2ceb-8e42-a9a7-\
c3a58e9ca630"],

Cell[BoxData[{
 RowBox[{"Clear", "[", "\[CapitalPi]", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[CapitalPi]", "[", 
    RowBox[{"\[Xi]_", ",", "\[Zeta]_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"-", 
     FractionBox["\[Eta]", 
      RowBox[{"2", "\[Pi]", " ", "\[ScriptCapitalS]"}]]}], 
    FractionBox[
     RowBox[{"8", " ", 
      SqrtBox[
       RowBox[{"1", "+", 
        RowBox[{"2", "\[ScriptCapitalA]"}]}]], " ", 
      SuperscriptBox["\[ScriptCapitalA]", 
       RowBox[{"3", "/", "2"}]], " ", 
      RowBox[{"(", 
       RowBox[{"1", "-", "\[Beta]"}], ")"}]}], 
     RowBox[{
      SqrtBox["\[Pi]"], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         SqrtBox[
          RowBox[{"1", "+", 
           RowBox[{"2", "\[ScriptCapitalA]"}]}]], " ", 
         RowBox[{"(", 
          RowBox[{"\[ScriptCapitalA]", "-", "\[Beta]"}], ")"}]}], "+", 
        "\[Beta]"}], ")"}]}]], 
    RowBox[{"NIntegrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         FractionBox["1", 
          RowBox[{"2", " ", 
           SqrtBox["s"]}]], "-", 
         FractionBox[
          RowBox[{"DawsonF", "[", 
           SqrtBox[
            FractionBox["s", "\[ScriptCapitalA]"]], "]"}], 
          SqrtBox["\[ScriptCapitalA]"]]}], ")"}], 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"-", 
           FractionBox[
            RowBox[{"\[Xi]", "-", "s"}], 
            SuperscriptBox["r", "2"]]}], "+", 
          RowBox[{
           RowBox[{"Exp", "[", 
            RowBox[{"\[Xi]", "-", "s"}], "]"}], 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              FractionBox[
               RowBox[{"\[Xi]", "-", "s"}], "r"], 
              RowBox[{"BesselK", "[", 
               RowBox[{"1", ",", " ", "r"}], "]"}]}], "-", 
             RowBox[{"BesselK", "[", 
              RowBox[{"0", ",", " ", "r"}], "]"}]}], ")"}]}]}], "/.", 
         RowBox[{"{", 
          RowBox[{"r", "->", 
           SqrtBox[
            RowBox[{
             SuperscriptBox[
              RowBox[{"(", 
               RowBox[{"\[Xi]", "-", "s"}], ")"}], "2"], "+", 
             SuperscriptBox["\[Zeta]", "2"]}]]}], "}"}]}], ")"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"s", ",", " ", "0", ",", "\[Xi]", ",", " ", "\[Infinity]"}], 
       "}"}], ",", 
      RowBox[{"Method", "->", 
       RowBox[{"{", "\"\<PrincipalValue\>\"", "}"}]}]}], "]"}]}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{
  3.990006438347067*^9, {3.990006813228176*^9, 3.9900068135720005`*^9}, {
   3.9900641812633705`*^9, 3.99006418453611*^9}, 
   3.9900668138989544`*^9},ExpressionUUID->"242087a7-e738-124c-a560-\

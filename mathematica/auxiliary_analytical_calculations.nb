     FractionBox[
      RowBox[{"2", 
       RowBox[{"(", 
        RowBox[{"1", "-", "\[Beta]"}], ")"}]}], "\[Beta]"], 
     SuperscriptBox["\[Eta]", "2"]}]}], " ", ";"}], 
  RowBox[{"(*", 

Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{"J", ",", " ", "\[CapitalPi]ref"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[CapitalPi]0", "=", 
   RowBox[{
    FractionBox[
     RowBox[{
      SuperscriptBox["a1", 
       RowBox[{"3", "/", "2"}]], " ", 
      SqrtBox[
       RowBox[{"1", "+", "a1"}]], " ", "\[Beta]"}], 
     RowBox[{
      SqrtBox[
       RowBox[{"2", " ", "\[Pi]"}]], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         SqrtBox[
          RowBox[{"1", "+", "a1"}]], " ", 
         RowBox[{"(", 
          RowBox[{"a1", "-", 
           RowBox[{"2", " ", "\[Beta]"}]}], ")"}]}], "+", 
        RowBox[{"2", " ", "\[Beta]"}]}], ")"}], " ", "\[Eta]"}]], "//", 
    "N"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"J", "[", 
    RowBox[{"X_", ",", "Y_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "R", "}"}], ",", 
     RowBox[{
      RowBox[{"R", "=", 
       SqrtBox[
        RowBox[{
         SuperscriptBox["X", "2"], "+", 
         SuperscriptBox["Y", "2"]}]]}], ";", 
      RowBox[{
       RowBox[{"Exp", "[", 
        RowBox[{"-", 
         FractionBox["X", "a1"]}], "]"}], " ", 
       FractionBox[
        SqrtBox[
         RowBox[{"R", "+", "X"}]], "R"], 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Exp", "[", 
          RowBox[{"-", 
           FractionBox[
            RowBox[{"X", "+", "R"}], "2"]}], "]"}], "-", "1"}], ")"}]}]}]}], 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[CapitalPi]ref", "[", 
    RowBox[{"\[Xi]_", ",", "\[Zeta]_"}], "]"}], ":=", 
   RowBox[{"Module", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"X", ",", "Y"}], "}"}], ",", 
     RowBox[{
      RowBox[{"X", "=", 
       RowBox[{
        RowBox[{"-", "2"}], " ", "\[Xi]"}]}], ";", " ", 
      RowBox[{"Y", "=", 
       RowBox[{"2", " ", "\[Zeta]"}]}], ";", 
      RowBox[{"\[CapitalPi]0", 
       RowBox[{"(", 
        RowBox[{
         FractionBox[
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"-", "1"}], "+", 
             SuperscriptBox["\[ExponentialE]", 
              RowBox[{
               RowBox[{"-", 
                FractionBox["X", "2"]}], "-", 
               RowBox[{
                FractionBox["1", "2"], " ", 
                SqrtBox[
                 RowBox[{
                  SuperscriptBox["X", "2"], "+", 
                  SuperscriptBox["Y", "2"]}]]}]}]]}], ")"}], " ", 
           SqrtBox[
            RowBox[{"X", "+", 
             SqrtBox[
              RowBox[{
               SuperscriptBox["X", "2"], "+", 
               SuperscriptBox["Y", "2"]}]]}]]}], 
          SqrtBox[
           RowBox[{
            SuperscriptBox["X", "2"], "+", 
            SuperscriptBox["Y", "2"]}]]], "-", 
         RowBox[{
          FractionBox[
           RowBox[{"Exp", "[", 
            FractionBox["X", "a1"], "]"}], "a1"], 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"NIntegrate", "[", 
             RowBox[{
              RowBox[{"J", "[", 
               RowBox[{"x", ",", "Y"}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"x", ",", "X", ",", "0"}], "}"}], ",", 
              RowBox[{"Method", "->", 
               RowBox[{"{", "\"\<GlobalAdaptive\>\"", "}"}]}], ",", " ", 
              RowBox[{"MaxRecursion", "->", "20"}]}], "]"}], "+", 
            RowBox[{"NIntegrate", "[", 
             RowBox[{
              RowBox[{"J", "[", 
               RowBox[{"x", ",", "Y"}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"x", ",", "0", ",", "\[Infinity]"}], "}"}], ",", 
              RowBox[{"Method", "->", 
               RowBox[{"{", "\"\<GlobalAdaptive\>\"", "}"}]}], ",", 
              RowBox[{"MaxRecursion", "->", "20"}]}], "]"}]}], ")"}]}]}], 
        ")"}]}]}]}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.9900053690436516`*^9, 3.990005391355871*^9}, {

Cell[BoxData[{
 RowBox[{"Clear", "[", " ", 
  RowBox[{
  "ExpK0", ",", " ", "ExpK1", ",", "\[ScriptCapitalS]s", ",", " ", 
   "\[ScriptCapitalS]e", ",", " ", "ExpErfc"}], "]"}], "\n", 
 RowBox[{"SetAttributes", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
    "ExpK0", ",", " ", "ExpK1", ",", "  ", "\[ScriptCapitalS]s", ",", " ", 
     "\[ScriptCapitalS]e", ",", " ", "ExpErfc"}], "}"}], ",", "Listable"}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ExpK0", "[", 
    RowBox[{"x0_", "?", "NumericQ"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"x", "=", "x0"}], "}"}], ",", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"x", ">", "700"}], ",", 
        RowBox[{
         SqrtBox[
          FractionBox["\[Pi]", 
           RowBox[{"2", "x"}]]], "-", 
         RowBox[{
          FractionBox[
           SqrtBox["\[Pi]"], "4"], "  ", 
          SuperscriptBox[
           RowBox[{"(", 
            FractionBox["1", 
             RowBox[{"2", "x"}]], ")"}], 
           RowBox[{"3", "/", "2"}]]}], "+", 
         RowBox[{
          FractionBox[
           RowBox[{"9", 
            SqrtBox["\[Pi]"]}], "32"], "  ", 
          SuperscriptBox[
           RowBox[{"(", 
            FractionBox["1", 
             RowBox[{"2", "x"}]], ")"}], 
           RowBox[{"5", "/", "2"}]]}]}], ",", 
        RowBox[{
         RowBox[{"Exp", "[", "x", "]"}], 
         RowBox[{"BesselK", "[", 
          RowBox[{"0", ",", 
           RowBox[{"Abs", "[", "x", "]"}]}], "]"}]}]}], "]"}]}], "]"}], "//", 
    "N"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ExpK1", "[", 
    RowBox[{"x0_", "?", "NumericQ"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"x", "=", "x0"}], "}"}], ",", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"x", ">", "700"}], ",", 
        RowBox[{
         SqrtBox[
          FractionBox["\[Pi]", 
           RowBox[{"2", "x"}]]], " ", "+", 
         RowBox[{
          FractionBox[
           RowBox[{"3", 
            SqrtBox["\[Pi]"]}], "4"], "  ", 
          SuperscriptBox[
           RowBox[{"(", 
            FractionBox["1", 
             RowBox[{"2", "x"}]], ")"}], 
           RowBox[{"3", "/", "2"}]]}], "-", 
         RowBox[{
          FractionBox[
           RowBox[{"15", 
            SqrtBox["\[Pi]"]}], "32"], "  ", 
          SuperscriptBox[
           RowBox[{"(", 
            FractionBox["1", 
             RowBox[{"2", "x"}]], ")"}], 
           RowBox[{"5", "/", "2"}]]}]}], ",", 
        RowBox[{
         RowBox[{"Exp", "[", "x", "]"}], 
         RowBox[{"BesselK", "[", 
          RowBox[{"1", ",", 
           RowBox[{"Abs", "[", "x", "]"}]}], "]"}]}]}], "]"}]}], "]"}], "//", 
    "N"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[ScriptCapitalS]s", "[", "x_", "]"}], "=", 
   RowBox[{
    RowBox[{"-", 
     FractionBox["1", "x"]}], "-", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"ExpK0", "[", "x", "]"}], "-", 
      RowBox[{
       RowBox[{"Sign", "[", "x", "]"}], 
       RowBox[{"ExpK1", "[", "x", "]"}]}]}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[ScriptCapitalS]e", "[", 
    RowBox[{"x0_", "?", "NumericQ"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"x", "=", "x0"}], "}"}], ",", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Abs", "[", "x", "]"}], ">", 
        SuperscriptBox["10", 
         RowBox[{"-", "10"}]]}], ",", 
       RowBox[{
        FractionBox["1", "x"], 
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{"\[Beta]", 
           RowBox[{"(", 
            RowBox[{
             FractionBox["1", "x"], "-", 
             RowBox[{
              RowBox[{"Sign", "[", "x", "]"}], 
              RowBox[{"ExpK1", "[", "x", "]"}]}], "-", 
             RowBox[{"2", "x", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"ExpK0", "[", "x", "]"}], "-", 
                RowBox[{
                 RowBox[{"Sign", "[", "x", "]"}], 
                 RowBox[{"ExpK1", "[", "x", "]"}]}]}], ")"}]}]}], ")"}]}]}], 
         ")"}]}], ",", 
       RowBox[{
        FractionBox["1", "x"], 
        RowBox[{"(", 
         RowBox[{"1", "-", "\[Beta]"}], ")"}]}]}], "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ExpErfc", "[", 
    RowBox[{"x0_", "?", "NumericQ"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"x", "=", "x0"}], "}"}], ",", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"x", ">", "500"}], ",", 
        RowBox[{
         FractionBox["1", 
          SqrtBox[
           RowBox[{"\[Pi]", " ", "x"}]]], "-", 
         RowBox[{
          FractionBox["1", 
           RowBox[{"2", " ", 
            SqrtBox["\[Pi]"]}]], 
          SuperscriptBox[
           RowBox[{"(", 
            FractionBox["1", "x"], ")"}], 
           RowBox[{"3", "/", "2"}]]}], "+", 
         RowBox[{
          FractionBox[
           RowBox[{"3", " "}], 
           RowBox[{"4", " ", 
            SqrtBox["\[Pi]"]}]], 
          SuperscriptBox[
           RowBox[{"(", 
            FractionBox["1", "x"], ")"}], 
           RowBox[{"5", "/", "2"}]]}]}], ",", 
        RowBox[{
         RowBox[{"Exp", "[", "x", "]"}], 
         RowBox[{"Erfc", "[", 
          SqrtBox["x"], "]"}]}]}], "]"}]}], "]"}], "//", "N"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.9900086562489185`*^9, 3.9900086566087856`*^9}, {

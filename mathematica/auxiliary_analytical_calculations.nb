4fce5a1ff199"],

Cell[BoxData[{
 RowBox[{"Clear", "[", "\[CapitalSigma]", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[CapitalSigma]", "[", 
    RowBox[{
     RowBox[{"\[Xi]0_", "?", "NumericQ"}], ",", " ", 
     RowBox[{"\[ScriptCapitalA]0_", "?", "NumericQ"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Xi]", "=", "\[Xi]0"}], ",", " ", 
       RowBox[{"\[ScriptCapitalA]", "=", "\[ScriptCapitalA]0"}]}], "}"}], ",", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        FractionBox["1", 
         RowBox[{"4", "\[Pi]", 
          RowBox[{"(", 
           RowBox[{"1", "-", "\[Beta]"}], ")"}]}]], 
        FractionBox[
         RowBox[{"8", " ", 
          SuperscriptBox["\[ScriptCapitalA]", 
           RowBox[{"3", "/", "2"}]], " ", 
          RowBox[{"(", 
           RowBox[{"1", "-", "\[Beta]"}], ")"}]}], 
         RowBox[{

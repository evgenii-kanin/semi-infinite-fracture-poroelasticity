Cell[BoxData[{
 RowBox[{"Clear", "[", "\[CapitalPi]", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[CapitalPi]", "[", 
    RowBox[{"\[Xi]_", ",", "\[Zeta]_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{
     RowBox[{
      FractionBox["1", 
       RowBox[{"2", "\[Pi]", " ", "\[ScriptCapitalS]"}]], 
      FractionBox[
       RowBox[{"8", " ", 
        SqrtBox["\[ScriptCapitalA]"], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "1"}], "+", 
          SqrtBox[
           RowBox[{"1", "+", 
            RowBox[{"2", " ", "\[ScriptCapitalA]"}]}]]}], ")"}], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "1"}], "+", "\[Beta]"}], ")"}], " ", "\[Eta]"}], 
       RowBox[{
        SqrtBox["\[Pi]"], " ", 
        RowBox[{"(", 
         RowBox[{"\[ScriptCapitalA]", "+", "\[Beta]", "-", 
          RowBox[{
           SqrtBox[
            RowBox[{"1", "+", 
             RowBox[{"2", " ", "\[ScriptCapitalA]"}]}]], " ", "\[Beta]"}]}], 
         ")"}]}]], 
      RowBox[{"NIntegrate", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           FractionBox["1", 
            RowBox[{"2", " ", 
             SqrtBox["s"]}]], "-", 
           FractionBox[
            RowBox[{"DawsonF", "[", 
             SqrtBox[
              FractionBox["s", "\[ScriptCapitalA]"]], "]"}], 
            SqrtBox["\[ScriptCapitalA]"]]}], ")"}], 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"Exp", "[", 
             RowBox[{"\[Xi]", "-", "s"}], "]"}], 
            RowBox[{"BesselK", "[", 
             RowBox[{"0", ",", " ", "r"}], "]"}]}], "/.", 
           RowBox[{"{", 
            RowBox[{"r", "->", 
             SqrtBox[
              RowBox[{
               SuperscriptBox[
                RowBox[{"(", 
                 RowBox[{"\[Xi]", "-", "s"}], ")"}], "2"], "+", 
               SuperscriptBox["\[Zeta]", "2"]}]]}], "}"}]}], ")"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"s", ",", " ", "0", ",", "\[Xi]", ",", " ", "\[Infinity]"}], 
         "}"}], ",", 
        RowBox[{"Method", "->", 
         RowBox[{"{", "\"\<PrincipalValue\>\"", "}"}]}]}], "]"}]}], "-", 
     RowBox[{
      FractionBox["\[Eta]", 
       RowBox[{"2", "\[Pi]", " ", "\[ScriptCapitalS]"}]], 
      FractionBox[
       RowBox[{"8", " ", 
        SuperscriptBox["\[ScriptCapitalA]", 
         RowBox[{"3", "/", "2"}]], " ", 
        RowBox[{"(", 
         RowBox[{"1", "-", "\[Beta]"}], ")"}]}], 
       RowBox[{
        SqrtBox["\[Pi]"], " ", 
        RowBox[{"(", 
         RowBox[{"\[ScriptCapitalA]", "+", "\[Beta]", "-", 
          RowBox[{
           SqrtBox[
            RowBox[{
             RowBox[{"2", "\[ScriptCapitalA]"}], "+", "1"}]], "  ", 
           "\[Beta]"}]}], ")"}]}]], 
      RowBox[{"NIntegrate", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           FractionBox["1", 
            RowBox[{"2", " ", 
             SqrtBox["s"]}]], "-", 
           FractionBox[
            RowBox[{"DawsonF", "[", 
             SqrtBox[
              FractionBox["s", "\[ScriptCapitalA]"]], "]"}], 
            SqrtBox["\[ScriptCapitalA]"]]}], ")"}], 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"-", 
             FractionBox[
              RowBox[{"\[Xi]", "-", "s"}], 
              SuperscriptBox["r", "2"]]}], "+", 
            RowBox[{
             RowBox[{"Exp", "[", 
              RowBox[{"\[Xi]", "-", "s"}], "]"}], 
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                FractionBox[
                 RowBox[{"\[Xi]", "-", "s"}], "r"], 
                RowBox[{"BesselK", "[", 
                 RowBox[{"1", ",", " ", "r"}], "]"}]}], "-", 
               RowBox[{"BesselK", "[", 
                RowBox[{"0", ",", " ", "r"}], "]"}]}], ")"}]}]}], "/.", 
           RowBox[{"{", 
            RowBox[{"r", "->", 
             SqrtBox[
              RowBox[{
               SuperscriptBox[
                RowBox[{"(", 
                 RowBox[{"\[Xi]", "-", "s"}], ")"}], "2"], "+", 
               SuperscriptBox["\[Zeta]", "2"]}]]}], "}"}]}], ")"}]}], ",", 

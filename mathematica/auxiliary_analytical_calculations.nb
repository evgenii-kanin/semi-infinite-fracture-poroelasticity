 RowBox[{"Clear", "[", 
  RowBox[{"SqrtFunc", ",", "\[ScriptCapitalK]Func"}], "]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"SqrtFunc", "[", "s_", "]"}], ":=", 
   RowBox[{
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"-", "I"}], " ", 
      RowBox[{"Pi", "/", "4"}]}], "]"}], "*", 
    RowBox[{"Sqrt", "[", 
     RowBox[{"I", " ", "s"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[ScriptCapitalK]Func", "[", 
    RowBox[{
     RowBox[{"\[Beta]_", "?", "NumericQ"}], ",", " ", 
     RowBox[{"\[ScriptCapitalA]_", "?", "NumericQ"}]}], "]"}], ":=", 
   RowBox[{"Re", "[", 
    RowBox[{
     RowBox[{"-", 
      FractionBox[
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", "\[ImaginaryI]"}], " ", 
         RowBox[{"\[Pi]", "/", "4"}]}], "]"}], 
       RowBox[{"4", " ", "\[ImaginaryI]", " ", 
        SqrtBox["\[Pi]"]}]]}], 
     RowBox[{"NIntegrate", "[", 
      RowBox[{
       RowBox[{"(", 
        FractionBox[
         RowBox[{"1", "-", 
          RowBox[{"Exp", "[", 
           RowBox[{"\[ImaginaryI]", " ", "s"}], "]"}]}], 
         RowBox[{"s", 
          RowBox[{"(", 
           RowBox[{
            FractionBox["1", 
             RowBox[{"1", "-", "\[Beta]"}]], "+", 
            RowBox[{
             FractionBox[
              RowBox[{"\[ImaginaryI]", " ", "s", " ", "\[Beta]"}], 
              RowBox[{"\[ScriptCapitalA]", " ", 
               RowBox[{"(", 
                RowBox[{"1", "-", "\[Beta]"}], ")"}]}]], 
             RowBox[{"(", 
              RowBox[{"1", "-", " ", 
               FractionBox[
                RowBox[{"SqrtFunc", "[", 
                 RowBox[{"s", "-", 
                  RowBox[{"2", "\[ImaginaryI]", " ", "\[ScriptCapitalA]"}]}], 
                 "]"}], 
                RowBox[{"SqrtFunc", "[", "s", "]"}]]}], ")"}]}]}], ")"}], 
          RowBox[{"SqrtFunc", "[", "s", "]"}]}]], ")"}], ",", 
       RowBox[{"{", 
        RowBox[{"s", ",", " ", 
         RowBox[{"-", "\[Infinity]"}], ",", " ", "0", ",", "\[Infinity]"}], 
        "}"}], ",", " ", 
       RowBox[{"Method", "->", "\"\<PrincipalValue\>\""}]}], "]"}]}], "]"}]}],

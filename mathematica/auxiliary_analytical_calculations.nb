  RowBox[{
   RowBox[{"\[ScriptCapitalA]", "=", "5"}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"the", " ", "dimensionless", " ", "loading", " ", "length"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"a1", "=", 
    RowBox[{"2", " ", "\[ScriptCapitalA]"}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "the", " ", "dimensionless", " ", "loading", " ", "length", " ", "used", " ",
      "in", " ", "the", " ", "Atkinson"}], "-", 
    RowBox[{"Craster", " ", "equations"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Beta]", "=", "0.125"}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"the", " ", "normalized", " ", "undrained"}], "-", 
    RowBox[{"drained", " ", 
     RowBox[{"Poisson", "'"}], "s", " ", "ratio", " ", "contrast"}]}], "*)"}],
   " "}], "\[IndentingNewLine]", 
 RowBox[{
